# Copy this to .env.local and fill in with values from your Firebase project.
# Console → Project settings → Your apps → Web app → SDK setup and configuration.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Course-lookup Worker URL (from `wrangler deploy` in worker/). Optional —
# leave blank to disable course search/import and use manual entry only.
VITE_COURSE_API_URL=
