rules_version = '2';

// scorePulse Firestore security rules.
//
//   users/{uid}/**   — per-user data (rounds, achievements). The owner can
//                      always read and write. Others may READ (never write) it
//                      only when the owner has opted in by setting their
//                      profile's isPublic flag to true.
//   profiles/{uid}   — lightweight public profile (display name, email,
//                      isPublic). Readable by any signed-in user so friends can
//                      be looked up by email; writable only by the owner. Note
//                      that stats themselves stay gated on isPublic below — a
//                      profile exposes only a name/email, never round data.
//   courses/{id}     — shared course catalog. Any signed-in user may read and
//                      add/update courses; nobody may delete them from the app
//                      (course data is shared, so deletes are admin-only via
//                      the console).
service cloud.firestore {
  match /databases/{database}/documents {

    // Minimal shape check so a signed-in client can't write junk into the
    // shared catalog: a course needs a name and a non-empty pars array.
    function isValidCourse(data) {
      return data.name is string
        && data.name.size() > 0
        && data.pars is list
        && data.pars.size() > 0;
    }

    // True when the user {uid} has opted to make their stats public.
    function statsArePublic(uid) {
      return exists(/databases/$(database)/documents/profiles/$(uid))
        && get(/databases/$(database)/documents/profiles/$(uid)).data.isPublic == true;
    }

    // Lightweight public profiles — used for friend lookup by email.
    match /profiles/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Per-user documents: owner reads/writes; others may read only when the
    // owner has made their stats public. Writes are always owner-only.
    match /users/{uid}/{document=**} {
      allow read: if request.auth != null
        && (request.auth.uid == uid || statsArePublic(uid));
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Shared, read-mostly course catalog.
    match /courses/{courseId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && isValidCourse(request.resource.data);
      allow delete: if false;
    }
  }
}
